# 컨테이너 환경변수·UID/GID·바인드 IP 템플릿. 실제 .env로 복사해 사용.
# cp .env.example .env

# 본인 host 사용자 이름. `whoami`로 확인 후 본인 값으로.
USERNAME=your-username

# 호스트 사용자의 UID/GID. `id -u`, `id -g`로 확인.
USER_UID=1000
USER_GID=1000

# 컨테이너 안에서 호스트 docker.sock에 접근할 때 사용할 GID.
# - 호스트 dockerd 사용 시. `getent group docker | cut -d: -f3` (보통 988)
# - rootless dockerd 사용 시. socket이 본인 소유라 GID 매칭 의미는 약함. 본인 GID(`id -g`) 그대로 둬도 OK.
DOCKER_GID=988

# 마운트할 docker.sock 호스트 경로. 사용자별로 다름.
# - 호스트 dockerd. /var/run/docker.sock
# - rootless dockerd. /run/user/$(id -u)/docker.sock
DOCKER_SOCK=/var/run/docker.sock

# SSH 호스트 포트. 한 머신에서 다중 사용자가 각자 dev 컨테이너를 띄울 때 충돌 회피용.
# 사용자별 고정 분배는 호스트 관리자에게 별도 채널로 받기. 본인 포트만 사용할 것.
# compose는 Tailscale IP에 SSH_PORT_TS만 publish함. 호스트 자기 자신에서도
# ssh -p ${SSH_PORT_TS} user@${TAILSCALE_IP}로 접속됨 (Tailscale이 자기 IP는 로컬 라우팅).
# SSH_PORT_LOCAL은 backward-compat fallback이라 같은 값으로 둬도 무방, 안 써도 됨.
SSH_PORT_TS=2222
SSH_PORT_LOCAL=2222

# Tailscale 메시 IP. `tailscale ip -4`로 확인.
TAILSCALE_IP=100.x.y.z
# LAN까지 허용하려면 docker-compose.yml의 ports에서 ${LAN_IP} 줄 주석 해제.
LAN_IP=192.168.x.y
